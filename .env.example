# ──────────────────────────────────────────────────
# Environment template — copy to .env.local for real values
# ──────────────────────────────────────────────────

# Base URL for API calls made via lib/api-client.ts.
#
# Default (unset): "/api" — same-origin Vercel routes.
# When a high-traffic endpoint migrates to Cloudflare Workers,
# set this to the absolute Worker URL, e.g.:
#   NEXT_PUBLIC_API_BASE=https://api.evanchang.workers.dev
#
# See docs/ARCHITECTURE.md for the Vercel + CF hybrid plan.
NEXT_PUBLIC_API_BASE=/api
